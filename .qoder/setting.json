{
  "permissions": {
    "allow": [
      "Read(./**)",
      "Edit(./src/**)",
      "Edit(./tests/**)",
      "Bash(npm run*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(grep*)",
      "Bash(ls*)",
      "WebFetch(domain:api.github.com)",
      "Read(~/Documents/PersonalKnowledge/**)",
      "Write(~/Documents/PersonalKnowledge/**)",
      "Bash(mkdir -p ~/Documents/PersonalKnowledge/**)"
    ],
    "ask": [
      "Bash(git commit*)",
      "Bash(git push*)",
      "Edit(./.qoder/**)",
      "Edit(./.qoderwork/**)"
    ],
    "deny": [
      "Bash(rm*)",
      "Bash(chmod*)",
      "Bash(sudo*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/**)"
    ]
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/prompt-guard.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/security-gate.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/auto-lint.sh",
            "timeout": 30
          }
        ]
      }
    ],
    "PostToolUseFailure": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/log-failure.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/notify-done.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/knowledge-trigger.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "prompt_input_exit",
        "hooks": [
          {
            "type": "command",
            "command": ".qoderwork/hooks/knowledge-trigger.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "userConfig": {
    "paradigmTemplateVersion": "V0.9",
    "knowledgeArchive": {
      "enabled": true,
      "targetDir": "~/Documents/PersonalKnowledge",
      "description": "控制 /archive-session 是否写入归档工作区。enabled=false 时仅生成内容预览，不写文件"
    },
    "knowledgeNotes": {
      "enabled": true,
      "notesDir": ".qoder/notes",
      "description": "控制是否在会话中自动创建草稿笔记到 .qoder/notes/。enabled=false 时，AI 不主动创建草稿文件"
    }
  }
}
